# Caminho do arquivo SQLite (em prod no Fly.io use /data/wedding.db)
DATABASE_PATH=./data/wedding.db

# Sessão (gere com: openssl rand -base64 48). MIN. 32 chars.
SESSION_PASSWORD=trocar-por-segredo-aleatorio-de-pelo-menos-32-caracteres

# CPF (somente numeros) que tem acesso ao /admin
ADMIN_CPF=00000000000

# Pix estatico
PIX_KEY=sua-chave-pix-aqui
PIX_RECEIVER_NAME=NOIVOS DA SILVA
PIX_RECEIVER_CITY=SAO PAULO
